& {
    Set-StrictMode -Version Latest
    $ErrorActionPreference = 'Stop'

    if ([Environment]::OSVersion.Platform -ne [PlatformID]::Win32NT) {
        throw 'Aquest instal·lador només es pot executar a Windows.'
    }

    $repository = 'jcorrius/catalanitzador-windows'
    $version = '__VERSION__'
    $zipName = "Catalanitzador.Windows-$version.zip"
    $expectedHash = '__ZIP_SHA256__'
    $expectedUri = [uri]'__ZIP_URI__'
    $directory = Join-Path $env:TEMP (
        "Catalanitzador-$version-" + [guid]::NewGuid().ToString('N')
    )
    $exitCode = $null
    $maximumDownloadBytes = 100MB

    function New-CatalanitzadorWebRequest {
        [CmdletBinding()]
        param(
            [Parameter(Mandatory)]
            [uri]$Uri
        )

        $request = [Net.HttpWebRequest]::Create($Uri)
        $request.AllowAutoRedirect = $false
        $request.Method = 'GET'
        $request.Timeout = 120000
        $request.ReadWriteTimeout = 120000
        $request.UserAgent = "Catalanitzador.Windows/$version"
        $request
    }

    function Test-CatalanitzadorReleaseUri {
        [CmdletBinding()]
        param(
            [Parameter(Mandatory)]
            [uri]$Uri
        )

        (
            $Uri.Scheme -ceq 'https' -and
            $Uri.DnsSafeHost -ceq 'release-assets.githubusercontent.com' -and
            $Uri.IsDefaultPort -and
            [string]::IsNullOrEmpty($Uri.UserInfo) -and
            [string]::IsNullOrEmpty($Uri.Fragment) -and
            $Uri.AbsolutePath -cmatch (
                '^/github-production-release-asset/[0-9]+/' +
                '[0-9a-f-]+$'
            )
        )
    }

    function Save-CatalanitzadorResponse {
        [CmdletBinding()]
        param(
            [Parameter(Mandatory)]
            [Net.HttpWebResponse]$Response,

            [Parameter(Mandatory)]
            [string]$DestinationPath
        )

        if ([int]$Response.StatusCode -ne 200) {
            throw "GitHub ha respost amb HTTP $([int]$Response.StatusCode)."
        }
        if (
            $Response.ContentLength -gt $maximumDownloadBytes
        ) {
            throw 'El paquet publicat supera la mida màxima admesa.'
        }

        $inputStream = $Response.GetResponseStream()
        $outputStream = [IO.File]::Open(
            $DestinationPath,
            [IO.FileMode]::CreateNew,
            [IO.FileAccess]::Write,
            [IO.FileShare]::None
        )
        try {
            $buffer = New-Object byte[] 81920
            [long]$totalBytes = 0
            while (($bytesRead = $inputStream.Read(
                        $buffer,
                        0,
                        $buffer.Length
                    )) -gt 0) {
                $totalBytes += $bytesRead
                if ($totalBytes -gt $maximumDownloadBytes) {
                    throw 'El paquet publicat supera la mida màxima admesa.'
                }
                $outputStream.Write($buffer, 0, $bytesRead)
            }
        }
        finally {
            $outputStream.Dispose()
            $inputStream.Dispose()
        }
    }

    function Save-CatalanitzadorReleaseAsset {
        [CmdletBinding()]
        param(
            [Parameter(Mandatory)]
            [uri]$Uri,

            [Parameter(Mandatory)]
            [string]$DestinationPath
        )

        $request = New-CatalanitzadorWebRequest -Uri $Uri
        $response = [Net.HttpWebResponse]$request.GetResponse()
        try {
            if ([int]$response.StatusCode -eq 200) {
                Save-CatalanitzadorResponse `
                    -Response $response `
                    -DestinationPath $DestinationPath
                return
            }

            if ([int]$response.StatusCode -notin @(301, 302, 303, 307, 308)) {
                throw (
                    "GitHub ha respost amb HTTP " +
                    "$([int]$response.StatusCode)."
                )
            }

            $redirectUri = $null
            if (-not [uri]::TryCreate(
                    $response.Headers['Location'],
                    [UriKind]::Absolute,
                    [ref]$redirectUri
                ) -or
                -not (Test-CatalanitzadorReleaseUri -Uri $redirectUri)) {
                throw 'GitHub ha retornat una redirecció no admesa.'
            }
        }
        finally {
            $response.Dispose()
        }

        $assetRequest = New-CatalanitzadorWebRequest -Uri $redirectUri
        $assetResponse = [Net.HttpWebResponse]$assetRequest.GetResponse()
        try {
            Save-CatalanitzadorResponse `
                -Response $assetResponse `
                -DestinationPath $DestinationPath
        }
        finally {
            $assetResponse.Dispose()
        }
    }

    New-Item -ItemType Directory -Path $directory | Out-Null
    try {
        $zipPath = Join-Path $directory $zipName
        $previousSecurityProtocol = [Net.ServicePointManager]::SecurityProtocol
        [Net.ServicePointManager]::SecurityProtocol = (
            $previousSecurityProtocol -bor [Net.SecurityProtocolType]::Tls12
        )
        try {
            Save-CatalanitzadorReleaseAsset `
                -Uri $expectedUri `
                -DestinationPath $zipPath
        }
        finally {
            [Net.ServicePointManager]::SecurityProtocol = (
                $previousSecurityProtocol
            )
        }

        $actualHash = (
            Get-FileHash -LiteralPath $zipPath -Algorithm SHA256
        ).Hash
        if ($actualHash -ine $expectedHash) {
            throw 'La suma SHA-256 del paquet no coincideix.'
        }

        if (Get-Command gh -ErrorAction SilentlyContinue) {
            & gh attestation verify $zipPath --repo $repository
            if ($LASTEXITCODE -ne 0) {
                throw 'La certificació de GitHub no és vàlida.'
            }
        }
        else {
            Write-Warning (
                "GitHub CLI no està instal·lat: s'ha verificat la suma " +
                'fixada, però no la certificació.'
            )
        }

        Expand-Archive -LiteralPath $zipPath -DestinationPath $directory
        $package = Join-Path $directory "Catalanitzador.Windows-$version"
        Get-ChildItem -LiteralPath $package -Recurse -File |
            Unblock-File

        & "$env:WINDIR\System32\WindowsPowerShell\v1.0\powershell.exe" `
            -NoLogo `
            -NoProfile `
            -ExecutionPolicy RemoteSigned `
            -File (Join-Path $package 'Invoke-Catalanitzador.ps1')
        $exitCode = $LASTEXITCODE
        if ($exitCode -notin @(0, 3010)) {
            throw "El Catalanitzador ha acabat amb el codi $exitCode."
        }
    }
    finally {
        Remove-Item `
            -LiteralPath $directory `
            -Recurse `
            -Force `
            -ErrorAction SilentlyContinue
    }

    if ($exitCode -eq 3010) {
        Write-Warning (
            'La configuració ha acabat correctament, però cal reiniciar Windows.'
        )
    }
}
